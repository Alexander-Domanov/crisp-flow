{
  "manifest_version": 3,
  "name": "CrispFlow",
  "version": "1.0.0",
  "description": "Optimize long AI chats by hiding old messages",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
